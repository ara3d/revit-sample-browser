<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:ExcelExporterImporter"
        xmlns:common="clr-namespace:ExcelExporterImporter.Common"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        x:Class="ExcelExporterImporter.Views.ExportWindow"
        Title="{Binding Title}" Height="700" Width="800" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="/Ara3D.RevitSampleBrowser;component/B1_Shared/Resources/iconapp.ico"
        ShowInTaskbar="False" MinWidth="500">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FFD1D2D3" Offset="0" />
            <GradientStop Color="White" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#94bfdf" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Row="0" Grid.Column="0" Margin="5" BorderBrush="Black" BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock FontSize="18" Text="{x:Static res:Resources.Schedule}" Foreground="Black" />
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#5979b6" Offset="1" />
                                <GradientStop Color="#0079b6" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <CheckBox FontSize="14" Grid.Column="0" VerticalAlignment="Center" Margin="7,0,0,0"
                                  IsChecked="{Binding CheckExportSchedule}" Command="{Binding Command}"
                                  CommandParameter="ExportSchedulesCheck" />
                        <TextBlock FontSize="14" Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FFF9F7F7">
                            <Run Text="{x:Static res:Resources.Name}" />
                        </TextBlock>
                    </Grid>
                    <ListBox Background="#FFEFF4FB" Grid.Row="1"
                             ItemsSource="{Binding OrderedSchedulesForExport}" FontSize="14">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked}">
                                    <CheckBox.Content>
                                        <TextBlock Text="{Binding Item}" />
                                    </CheckBox.Content>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="0" Grid.Column="1" Margin="5" BorderBrush="Black" BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock FontSize="18" Text="{x:Static res:Resources.Standards}" Foreground="Black" />
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#5979b6" Offset="1" />
                                <GradientStop Color="#0079b6" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="7,0,0,0"
                                  IsChecked="{Binding CheckExportStandard}" Command="{Binding Command}"
                                  CommandParameter="ExportStandardCheck" />
                        <TextBlock FontSize="14" Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FFF9F7F7">
                            <Run Text="{x:Static res:Resources.Name}" />
                        </TextBlock>
                    </Grid>
                    <ListBox FontSize="14" Grid.Row="1" ItemsSource="{Binding StandardsList}" Background="#FFEFF4FB">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked}">
                                    <CheckBox.Content>
                                        <TextBlock Text="{Binding Item}" />
                                    </CheckBox.Content>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" BorderBrush="Black" BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock FontSize="18" Text="{x:Static res:Resources.ExportMode}" Foreground="Black" />
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                 IsChecked="{Binding ExportModeUni, Mode=TwoWay}" />
                    <Image Grid.Row="0" Grid.Column="1" Source="/Ara3D.RevitSampleBrowser;component/B1_Shared/Resources/IconUniModeMiniBlue.png"
                           Width="40" Height="40" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="2" TextWrapping="Wrap" Foreground="Black" FontSize="16"
                               VerticalAlignment="Center" Margin="10,0,0,0">
                        <Run Text="{x:Static res:Resources.NoticeExportBasic}" />
                    </TextBlock>
                    <RadioButton Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                 IsChecked="{Binding ExportModeBid, Mode=TwoWay}" />
                    <Image Grid.Row="1" Grid.Column="1" Source="/Ara3D.RevitSampleBrowser;component/B1_Shared/Resources/IconBiModeMiniBlue.png"
                           Width="40" Height="40" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" Grid.Column="2" TextWrapping="Wrap" Foreground="Black" FontSize="16"
                               Margin="10,0,0,0" VerticalAlignment="Center">
                        <Run Text="{x:Static res:Resources.NoticeExportAvanced}" />
                    </TextBlock>
                </Grid>
            </GroupBox>
        </Grid>
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/bimone/addins-excelexporterimporter"
                           common:HyperlinkExtensions.IsExternal="true" TextDecorations="None">
                    <InlineUIContainer>
                        <Image Source="/Ara3D.RevitSampleBrowser;component/B1_Shared/Resources/logo.png" Height="55" Width="144" />
                    </InlineUIContainer>
                </Hyperlink>
            </TextBlock>
            <Button Grid.Column="1" FontWeight="Bold" Width="125" Height="40" Margin="0,0,10,0"
                    IsEnabled="{Binding EnableButtons}" Command="{Binding Command}" CommandParameter="OK">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{Binding IconButton}" Width="25" Height="25" />
                        <TextBlock FontSize="14" Margin="5,0,5,0" Text="{Binding ButtonText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</Window>
