<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:ExcelExporterImporter"
        xmlns:common="clr-namespace:ExcelExporterImporter.Common"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        x:Class="ExcelExporterImporter.Views.ImportWindow"
        Title="{Binding Title}" Height="700" Width="800" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="/Ara3D.RevitSampleBrowser;component/B1_Shared/Resources/iconapp.ico"
        ShowInTaskbar="False" MinWidth="500">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FFD1D2D3" Offset="0" />
            <GradientStop Color="White" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#b6d4f5" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" BorderBrush="Black" BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock FontSize="18" Text="{x:Static res:Resources.Notice}" Foreground="Black" />
                </GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="14" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap"
                               Foreground="Black" Margin="5,0,5,0">
                        <Run Text="{x:Static res:Resources.NoticeImport}" />
                    </TextBlock>
                    <Image Grid.Column="1" Source="/Ara3D.RevitSampleBrowser;component/B1_Shared/Resources/IconBiModeMiniBlue.png"
                           Width="40" Height="40" />
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" BorderBrush="Black" BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock FontSize="18" Text="{x:Static res:Resources.ImportElementFormExcelFile}" Foreground="Black" />
                </GroupBox.Header>
                <DockPanel Margin="5">
                    <Label FontSize="14" Foreground="Black" Content="{x:Static res:Resources.File}" Padding="0"
                           VerticalAlignment="Center" />
                    <Button FontSize="14" Content="{x:Static res:Resources.Browse}" HorizontalAlignment="Right" Width="80"
                            IsEnabled="{Binding EnableButtons}" Command="{Binding Command}"
                            CommandParameter="BrowseImportFolder" DockPanel.Dock="Right" Height="25" />
                    <TextBox FontSize="14" Background="#FFEFF4FB" IsReadOnly="True" MinWidth="320"
                             Text="{Binding ImportFolder, Mode=TwoWay}" Margin="5,0" />
                </DockPanel>
            </GroupBox>
            <GroupBox Grid.Row="2" Grid.Column="0" Margin="5" BorderBrush="Black" BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock FontSize="18" Text="{x:Static res:Resources.AvailableImport}" Foreground="Black" />
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#7b99b8" Offset="1" />
                                <GradientStop Color="#32506c" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <CheckBox FontSize="14" Grid.Column="0" VerticalAlignment="Center" Margin="7,0,0,0"
                                  IsChecked="{Binding CheckAllImport}" Command="{Binding Command}"
                                  CommandParameter="ImportCheck" />
                        <TextBlock FontSize="14" Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FFF9F7F7">
                            <Run Text="{x:Static res:Resources.Name}" />
                        </TextBlock>
                    </Grid>
                    <ListBox FontSize="14" Grid.Row="1" ItemsSource="{Binding OrderedItemsForImport}" Background="#FFEFF4FB">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked}">
                                    <CheckBox.Content>
                                        <TextBlock Text="{Binding Item}" />
                                    </CheckBox.Content>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="2" Grid.Column="1" Margin="5" BorderBrush="Black" BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock FontSize="18" Text="{x:Static res:Resources.NotAvailableForImport}" Foreground="Black" />
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FFE07C77" Offset="1" />
                                <GradientStop Color="#FF7C4641" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <TextBlock FontSize="14" Grid.Row="0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FFF9F7F7">
                            <Run Text="{x:Static res:Resources.Name}" />
                        </TextBlock>
                    </Grid>
                    <ListBox FontSize="14" Grid.Row="1" ItemsSource="{Binding OrderedItemsForNotImport}" Background="#FFF7EFED">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsEnabled="False" IsChecked="False">
                                    <CheckBox.Content>
                                        <TextBlock Text="{Binding Item}" />
                                    </CheckBox.Content>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
        </Grid>
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/bimone/addins-excelexporterimporter"
                           common:HyperlinkExtensions.IsExternal="true" TextDecorations="None">
                    <InlineUIContainer>
                        <Image Source="/Ara3D.RevitSampleBrowser;component/B1_Shared/Resources/logo.png" Height="55" Width="144" />
                    </InlineUIContainer>
                </Hyperlink>
            </TextBlock>
            <Button Grid.Column="1" FontWeight="Bold" Width="125" Height="40" Margin="0,0,10,0"
                    IsEnabled="{Binding EnableButtons}" Command="{Binding Command}" CommandParameter="OK">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{Binding IconButton}" Width="25" Height="25" />
                        <TextBlock FontSize="14" Margin="5,0,5,0" Text="{Binding ButtonText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</Window>
